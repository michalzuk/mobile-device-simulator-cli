{
  "name": "mobile-device-simulator-cli",
  "version": "0.1.0",
  "description": "TypeScript CLI to manage iOS and Android simulators",
  "type": "module",
  "bin": {
    "mobile-device-simulator": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "tsx --test \"src/**/*.test.ts\""
  },
  "keywords": [
    "cli",
    "ios",
    "android",
    "simulator",
    "emulator"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
